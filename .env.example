# Copie ce fichier en ".env" et remplis les vraies valeurs
# Ne jamais commiter le fichier ".env" réel sur GitHub (il contient des secrets)

# --- Base de données PostgreSQL (fournie par Neon) ---
# Va sur neon.tech, crée un projet gratuit, puis copie l'URL de connexion
# (Dashboard Neon → "Connection string" → commence par postgresql://...)
DATABASE_URL=postgresql://utilisateur:motdepasse@ep-xxxx.neon.tech/nom_de_base?sslmode=require

# --- Port du serveur (Render le définit automatiquement, ne pas y toucher) ---
PORT=3000

# --- Clé API de l'IA (OpenAI, Anthropic, etc. — à donner plus tard) ---
AI_API_KEY=

# --- Clé Unsplash pour récupérer une photo libre de droit par article ---
# Gratuit : crée un compte sur unsplash.com/developers, crée une "application",
# puis copie la valeur "Access Key" depuis le tableau de bord de ton appli
UNSPLASH_ACCESS_KEY=

# --- Clé secrète pour protéger la route de génération automatique ---
# Choisis une chaîne aléatoire longue, ex: générée sur https://www.uuidgenerator.net/
# C'est CETTE clé qu'il faudra mettre dans l'URL configurée sur cron-job.org
CRON_SECRET_KEY=change-moi-en-une-cle-aleatoire-longue

# --- Mot de passe pour accéder à la zone privée de publication (/admin) ---
ADMIN_PASSWORD=choisis-un-mot-de-passe-solide

# --- Clé secrète pour sécuriser les sessions de connexion admin ---
# Génère aussi une chaîne aléatoire longue, différente de CRON_SECRET_KEY
SESSION_SECRET=change-moi-aussi-en-une-cle-aleatoire-longue
