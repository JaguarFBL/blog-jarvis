<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= article.titre %> — Le Fil</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="tiroir-fond" id="tiroir-fond"></div>
    <nav class="tiroir-menu" id="tiroir-menu">
        <div class="tiroir-entete">
            <span class="tiroir-logo">Le Fil</span>
        </div>
        <a href="/" class="tiroir-lien">Accueil</a>
        <a href="/admin/connexion" class="tiroir-lien">Publier un article</a>

        <% if (liensUtiles && liensUtiles.length > 0) { %>
            <p class="tiroir-categorie">Liens utiles</p>
            <% liensUtiles.forEach(lien => { %>
                <a href="<%= lien.url %>" class="tiroir-lien" target="_blank" rel="noopener"><%= lien.titre %></a>
            <% }) %>
        <% } %>
    </nav>

    <div class="conteneur">
        <div class="bandeau-haut">
            <button class="bouton-menu" id="bouton-menu" aria-label="Ouvrir le menu">
                <span></span><span></span><span></span>
            </button>
            <a href="/" class="fil-retour" style="margin: 0;">← Retour aux articles</a>
        </div>

        <article>
            <% if (images.length > 0) { %>
                <img src="<%= images[0].url %>" alt="" class="article-image">
                <p class="article-image-legende">
                    Photo : <a href="<%= images[0].photographeUrl %>" target="_blank" rel="noopener"><%= images[0].photographe %></a> / Unsplash
                </p>
            <% } %>

            <div class="article-entete">
                <h1 class="article-titre"><%= article.titre %></h1>
                <div class="article-meta">
                    <span><%= article.categorie %></span>
                    <span>·</span>
                    <time><%= new Date(article.date_publication).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></time>
                    <% if (article.genere_par_ia) { %>
                        <span class="badge-ia">Rédigé par IA</span>
                    <% } %>
                </div>
            </div>

            <% parties.forEach((partie, index) => { %>
                <div class="article-corps"><%= partie %></div>

                <% if (images[index + 1]) { %>
                    <div class="image-intercalee">
                        <img src="<%= images[index + 1].url %>" alt="">
                        <p class="legende-photo">
                            Photo : <a href="<%= images[index + 1].photographeUrl %>" target="_blank" rel="noopener"><%= images[index + 1].photographe %></a> / Unsplash
                        </p>
                    </div>
                <% } %>
            <% }) %>
        </article>

        <section class="section-commentaires" id="commentaires">
            <h2><%= commentaires.length %> commentaire<%= commentaires.length !== 1 ? 's' : '' %></h2>

            <form class="formulaire-commentaire" method="POST" action="/article/<%= article.slug %>/commentaire">
                <input type="text" name="nom_auteur" placeholder="Votre nom" required maxlength="100">
                <textarea name="contenu" placeholder="Votre commentaire..." required maxlength="2000"></textarea>
                <button type="submit">Publier le commentaire</button>
            </form>

            <% if (commentaires.length === 0) { %>
                <p class="aucun-commentaire">Aucun commentaire pour l'instant. Soyez le premier à réagir.</p>
            <% } else { %>
                <% commentaires.forEach(c => { %>
                    <div class="commentaire">
                        <div class="commentaire-auteur">
                            <%= c.nom_auteur %>
                            <span class="commentaire-date"><%= new Date(c.date_creation).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %></span>
                        </div>
                        <div class="commentaire-contenu"><%= c.contenu %></div>
                    </div>
                <% }) %>
            <% } %>
        </section>
    </div>

    <script src="/js/tiroir.js"></script>
</body>
</html>
