<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Le Fil — Actualité France & Monde</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="conteneur">
        <div class="bandeau-haut">
            <span><%= new Date().toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) %></span>
            <% if (meteo) { %>
                <div class="bandeau-meteo">
                    <span>Paris</span>
                    <strong><%= meteo.temperature %>°C</strong>
                    <span><%= meteo.description %></span>
                </div>
            <% } %>
        </div>

        <header class="entete">
            <a href="/" class="logo-blog">Le Fil</a>
            <div class="entete-ligne">
                <p class="sous-titre">L'actualité résumée chaque jour</p>
                <div class="fil-statut">
                    <span class="point-actif"></span>
                    Rédigé par IA
                </div>
            </div>
        </header>

        <% if (chiffreDuJour) { %>
            <div class="encart-chiffre">
                <p class="eyebrow">Le chiffre du jour</p>
                <p class="chiffre"><%= chiffreDuJour.chiffre %></p>
                <p class="legende"><%= chiffreDuJour.legende %></p>
            </div>
        <% } %>

        <% if (brefs && brefs.length > 0) { %>
            <div class="section-brefs">
                <p class="eyebrow">En bref</p>
                <ul class="liste-brefs">
                    <% brefs.forEach(b => { %>
                        <li><%= b.contenu %></li>
                    <% }) %>
                </ul>
            </div>
        <% } %>

        <main class="liste-articles">
            <% if (articles.length === 0) { %>
                <div class="vide">
                    <p>Aucun article pour l'instant. Le premier arrive bientôt.</p>
                </div>
            <% } else { %>
                <% articles.forEach(article => { %>
                    <a href="/article/<%= article.slug %>" class="carte-article">
                        <div class="carte-meta">
                            <span><%= article.categorie %></span>
                            <time><%= new Date(article.date_publication).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }) %></time>
                        </div>
                        <h2 class="carte-titre"><%= article.titre %></h2>
                        <p class="carte-resume"><%= article.resume %></p>
                    </a>
                <% }) %>
            <% } %>
        </main>
    </div>
</body>
</html>
