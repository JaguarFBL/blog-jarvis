<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Le Fil — Actualité France & Monde</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="tiroir-fond" id="tiroir-fond"></div>
    <nav class="tiroir-menu" id="tiroir-menu">
        <div class="tiroir-entete">
            <span class="tiroir-logo">Le Fil</span>
        </div>
        <a href="/" class="tiroir-lien">Accueil</a>
        <a href="/admin/connexion" class="tiroir-lien">Publier un article</a>
        <a href="/admin/connexion" class="tiroir-lien">Espace privé</a>
    </nav>

    <div class="conteneur">
        <div class="bandeau-haut">
            <button class="bouton-menu" id="bouton-menu" aria-label="Ouvrir le menu">
                <span></span><span></span><span></span>
            </button>
            <span><%= new Date().toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) %></span>
            <% if (meteo) { %>
                <div class="bandeau-meteo">
                    <span>Paris</span>
                    <strong><%= meteo.temperature %>°C</strong>
                    <span><%= meteo.description %></span>
                </div>
            <% } %>
        </div>

        <header class="entete">
            <a href="/" class="logo-blog">Le Fil</a>
            <div class="entete-ligne">
                <p class="sous-titre">L'actualité résumée chaque jour</p>
                <div class="fil-statut">
                    <span class="point-actif"></span>
                    Rédigé par IA
                </div>
            </div>
        </header>

        <% if (chiffreDuJour) { %>
            <div class="encart-chiffre">
                <p class="eyebrow">Le chiffre du jour</p>
                <p class="chiffre"><%= chiffreDuJour.chiffre %></p>
                <p class="legende"><%= chiffreDuJour.legende %></p>
            </div>
        <% } %>

        <% if (brefs && brefs.length > 0) { %>
            <div class="section-brefs">
                <p class="eyebrow">En bref</p>
                <div class="brefs-scroll">
                    <% brefs.forEach(b => { %>
                        <div class="bref-pastille"><%= b.contenu %></div>
                    <% }) %>
                </div>
            </div>
        <% } %>

        <main class="liste-articles">
            <% if (articles.length === 0) { %>
                <div class="vide">
                    <p>Aucun article pour l'instant. Le premier arrive bientôt.</p>
                </div>
            <% } else { %>
                <% articles.forEach((article, index) => { %>
                    <% if (index === 0) { %>
                        <a href="/article/<%= article.slug %>" class="carte-article carte-article--vedette">
                            <% if (article.imageVignette) { %>
                                <img src="<%= article.imageVignette %>" alt="" class="carte-image">
                            <% } %>
                            <div class="carte-meta">
                                <span><%= article.categorie %></span>
                                <time><%= new Date(article.date_publication).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long' }) %></time>
                            </div>
                            <h2 class="carte-titre"><%= article.titre %></h2>
                            <p class="carte-resume"><%= article.resume %></p>
                        </a>
                    <% } else { %>
                        <a href="/article/<%= article.slug %>" class="carte-article carte-article--compacte">
                            <% if (article.imageVignette) { %>
                                <img src="<%= article.imageVignette %>" alt="" class="carte-image-petite">
                            <% } %>
                            <div class="carte-compacte-texte">
                                <div class="carte-meta">
                                    <span><%= article.categorie %></span>
                                </div>
                                <h2 class="carte-titre carte-titre--petit"><%= article.titre %></h2>
                            </div>
                        </a>
                    <% } %>
                <% }) %>
            <% } %>
        </main>
    </div>

    <script src="/js/tiroir.js"></script>
</body>
</html>
